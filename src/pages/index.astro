---
import PageLayout from '../layouts/BaseLayout.astro'
import Section from '../components/Section.astro'
import Card from '../components/Card.astro'
import ProjectCard from '../components/ProjectCard.astro'
import Label from '../components/Label.astro'
import SkillLayout from '../components/SkillLayout.astro'
import PostPreview from '@/components/blog/PostPreview.astro'

import { Image } from 'astro:assets'
import astro from '../assets/else-where.jpg'

import { sortMDByDate } from '@/utils'
import { fetchTistoryTopPosts } from '../utils/post'

const languages = ['java', 'kotlin', 'python', 'sql']
const frontend = ['typescript', 'tauri']
const backend = ['spring-boot', 'spring-batch', 'jpa']
const others = [
	'airflow',
	'kubernetes',
	'docker',
	'postgres',
	'valkey',
	'git',
	'ci/cd',
	'datadog',
	'aws',
	'self-hosted'
]

const MAX_POSTS = 10
const tistoryPosts = await fetchTistoryTopPosts()
const allPostsByDate = sortMDByDate(tistoryPosts).slice(0, MAX_POSTS)
---

<PageLayout meta={{ title: 'Home' }}>
	<div class='flex w-full flex-col gap-y-10'>
		<section class='flex flex-col items-center gap-y-7'>
			<Image src={astro} alt='profile photo' class='h-36 w-auto rounded-full' loading='eager' />

			<div class='flex flex-col items-center gap-y-4'>
				<h1 class='text-3xl font-bold'>
					물류·택배에서 2천만 고객 CRM 플랫폼으로, 도메인을 넓혀온 백엔드 엔지니어 고형규입니다.
				</h1>
				<div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
					<Label title='GS 리테일'>
						<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' class='h-5 w-5' slot='icon'>
							<path
								fill='currentColor'
								d='M4.615 20q-.69 0-1.152-.462Q3 19.075 3 18.385v-9.77q0-.69.463-1.152Q3.925 7 4.615 7H9V5.615q0-.69.463-1.152Q9.925 4 10.615 4h2.77q.69 0 1.153.463q.462.462.462 1.152V7h4.385q.69 0 1.152.463q.463.462.463 1.152v9.77q0 .69-.462 1.152q-.463.463-1.153.463zm0-1h14.77q.23 0 .423-.192q.192-.193.192-.423v-9.77q0-.23-.192-.423Q19.615 8 19.385 8H4.615q-.23 0-.423.192Q4 8.385 4 8.615v9.77q0 .23.192.423q.193.192.423.192M10 7h4V5.615q0-.23-.192-.423Q13.615 5 13.385 5h-2.77q-.23 0-.423.192q-.192.193-.192.423zM4 19V8z'
							></path>
						</svg>
					</Label>
					<Label title='GitHub' as='a' href='https://github.com/GHGHGHKO' target='_blank'>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							viewBox='0 0 16 16'
							slot='icon'
							class='h-5 w-5 text-foreground/75'
						>
							<path
								fill='currentColor'
								d='M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13 -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07 -1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.548 7.548 0 0 1 2-.27c.68.003 1.36.092 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.001 8.001 0 0 0 16 8 c0-4.42-3.58-8-8-8z'
							></path>
						</svg>
					</Label>
					<Label
						title='Instagram'
						as='a'
						href='https://www.instagram.com/hg____ko/'
						target='_blank'
					>
						<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' class='h-5 w-5' slot='icon'>
							<rect
								x='3'
								y='3'
								width='18'
								height='18'
								rx='5'
								stroke='currentColor'
								fill='none'
								stroke-width='1.5'></rect>
							<circle cx='12' cy='12' r='3.5' stroke='currentColor' fill='none' stroke-width='1.5'
							></circle>
							<circle cx='17' cy='7' r='1' fill='currentColor'></circle>
						</svg>
					</Label>
					<Label title='gudrb963@gmail.com'>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							viewBox='0 0 24 24'
							slot='icon'
							class='h-5 w-5 text-foreground/75'
						>
							<path
								fill='currentColor'
								d='M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 2v.01L12 13 4 6.01V6h16zM4 18V8l8 5 8-5v10H4z'
							></path>
						</svg>
					</Label>
				</div>
			</div>
		</section>

		<Section title='About'>
			<div class='space-y-4 text-muted-foreground'>
				<p>
					대학 시절 창업(마인드패스)을 통해 AI 기반 서비스를 직접 만들어 보면서 개발에 본격적으로
					뛰어들었습니다. 이후 물류·택배 백엔드 개발자로 커리어를 시작했습니다.
				</p>

				<p>
					GS 네트웍스에서 토스·네이버·카카오·당근 등 50개 이상의 제휴사와 연동하고 외부 API
					장애를 직접 대응하면서, “서비스가 멈추지 않게 만드는 것(가용성)”이 저의 첫 번째 기준이
					됐습니다.
				</p>

				<p>
					GS 리테일에서는 IDC에서 AWS로 전환하는 과정에 함께하며, 인증 구조(세션 클러스터링 →
					RSA/KMS 기반 JWT), 배치 안정화, Datadog 기반 모니터링 체계 구축까지 서비스 전반을
					다뤘습니다. 배포나 장애 대응이 특정 작업자에게 의존하지 않도록 구조를 정리하는 걸 선호합니다.
				</p>

				<p>
					이후 CRM팀으로 이동하며 고객 약 2천만 명 규모의 통합 회원 플랫폼으로 도메인을 넓혔습니다.
					차세대 오픈 직후 투입돼 중단됐던 배치를 복구하고 개인정보 관련 버그를 수정하면서, 이슈는
					Datadog 로그/APM으로 빠르게 파악하고 임시 처방보다 “다음에 같은 일이 안 나게” 정리하는
					방식으로 해결해 왔습니다.
				</p>
			</div>
		</Section>

		<Section title='TL;DR'>
			<Card heading='💰 비용 / 구조 정리' imageClass='h-12 w-auto md:-left-28'>
				<div class='space-y-1 text-sm text-muted-foreground'>
					<div>EDB → Aurora PostgreSQL 전환(쿼리/운영 포인트 정리 포함)</div>
					<div>Airflow DAG 정리 및 스케줄 통합 (270 → 180)</div>
					<div>알림톡 에이전트/테이블 통합 (16 → 8)</div>
					<div>IDC → AWS 전환 과정에서 운영비와 장애 대응 부담을 낮추는 방향으로 정비</div>
				</div>
			</Card>

			<Card heading='🔒 인증 / 보안' imageClass='h-12 w-auto md:-left-28'>
				<div class='space-y-1 text-sm text-muted-foreground'>
					<div>세션 기반 인증을 JWT로 점진 전환</div>
					<div>RSA(KMS) 기반 JWT 도입(공개키 검증으로 인증 흐름 단순화)</div>
					<div>단말/모바일 앱 인증 흐름 정리 및 통합</div>
				</div>
			</Card>

			<Card heading='⚙️ 배치 / 안정성' imageClass='h-12 w-auto md:-left-28'>
				<div class='space-y-1 text-sm text-muted-foreground'>
					<div>K8s + Airflow 배치 구조 정리</div>
					<div>실패/지연이 잦은 작업은 원인 분석 후 구조 개선</div>
					<div>장애 시 서비스 영향 범위를 줄이기 위해 실행 단위/자원 분리</div>
				</div>
			</Card>

			<Card heading='📊 모니터링' imageClass='h-12 w-auto md:-left-28'>
				<div class='space-y-1 text-sm text-muted-foreground'>
					<div>Datadog APM 및 로그 수집 환경 구축</div>
					<div>개인정보 로그는 Marker 기반으로 분리/필터링</div>
					<div>장애 확인과 원인 추적에 걸리는 시간을 줄이는 방향으로 개선</div>
				</div>
			</Card>

			<Card heading='🏢 CRM / 고객 플랫폼' imageClass='h-12 w-auto md:-left-28'>
				<div class='space-y-1 text-sm text-muted-foreground'>
					<div>차세대 CRM 오픈 직후 투입 — 6개월 이상 중단된 운영 배치 3종 스케줄 재설계 및 복구</div>
					<div>고객 등급 일괄변경 API 설계 (1회 최대 100건, Partial Success 패턴)</div>
					<div>개인정보 오동기화 버그 수정 — 탈퇴 후 재가입 시 이전 정보 덮어쓰기 (월 약 2건)</div>
					<div>MCP 기반 AI 업무 자동화 도입 제안 (기획·개발팀 대상)</div>
				</div>
			</Card>
		</Section>

		{
			allPostsByDate.length > 0 && (
				<Section title='Posts'>
					<ul class='flex flex-col gap-y-2'>
						{allPostsByDate.map((p) => (
							<li class='flex flex-col gap-x-2 sm:flex-row'>
								<PostPreview post={p} />
							</li>
						))}
					</ul>
				</Section>
			)
		}

		<Section title='Experience'>
			<Card
				heading='GS 리테일'
				subheading='물류DX · CRM | 매니저 | 백엔드'
				date='Oct 2022 - 현재'
				imagePath='/src/assets/logo_gs_lg-removebg-preview.png'
				altText='GS Retail'
				imageClass='h-12 w-auto md:-left-28'
			>
				<ul class='space-y-7 text-muted-foreground'>
					<li>
						<div class='font-semibold text-foreground'>
							<a href='/blog/crm-platform' class='hover:underline'>차세대 통합 회원 플랫폼 안정화 (CRM팀)</a>
							<span class='ml-2 text-sm text-muted-foreground'>(2024.11–현재)</span>
						</div>
						<div class='mt-1 text-sm'>
							API/배치 개발 · Java / Spring Boot / PostgreSQL / Redis / Bamboo
						</div>
						<ul class='ml-4 mt-2 list-disc space-y-1 text-sm'>
							<li>
								차세대 플랫폼 오픈 직후 투입돼, 6개월 이상 미실행 상태였던 운영 배치 3종
								(임직원 비활성화·메일 발송·PMS 결과 반영)을 단순 재기동 없이 스케줄 재설계와
								데이터 정합성 검토를 포함해 복구
							</li>
							<li>
								개인정보 보호 대응으로 회원 로그인 이력 조회 API 설계·개발 (일 평균 약 200건)
								— 고객이 직접 본인 이력을 확인하는 보안·컴플라이언스 요건 반영
							</li>
							<li>
								고객 등급 일괄변경 API 설계·개발 — 1회 최대 100건·6개 테이블 트랜잭션 처리,
								Validation 실패 건은 Partial Success 패턴으로 미처리 건을 응답에 포함해 호출
								측 재처리 가능하게 설계
							</li>
							<li>
								GS 네트웍스 연동 개인정보 오동기화 수정 — 탈퇴 후 재가입 시 이전 정보
								덮어쓰기(월 약 2건, 개인정보 보호법 리스크 직결)를 외부 연동 플로우 데이터
								정합성 검토로 해결
							</li>
							<li>GS Pay 공유결제 구성원 닉네임 변경 버그 운영 핫픽스 대응</li>
							<li>
								MCP(Model Context Protocol) 기반 AI 업무 자동화 도입을 기획·개발팀에 제안
								— 반복 업무 자동화로 팀 업무 효율화 방향 제시
							</li>
						</ul>
					</li>

					<li>
						<div class='font-semibold text-foreground'>
							<a href='/blog/woori-delivery' class='hover:underline'>택배 서비스 Backend Monorepo 설계·구축</a>
							<span class='ml-2 text-sm text-muted-foreground'>(2023.11–2024.12)</span>
						</div>
						<div class='mt-1 text-sm'>
							백엔드 설계·개발 · Java / Spring Boot 3 / Spring Security / JWT(JWE) / KMS / K8s / Aurora Postgres / Datadog
						</div>
						<ul class='ml-4 mt-2 list-disc space-y-1 text-sm'>
							<li>우리동네GS 연동을 계기로 택배 서비스 backend monorepo 신규 설계 — 인증·인가·비즈니스 레이어 통합, 이후 물류센터·택배홈페이지·GSRETAIL·BACKOFFICE·전국 18,000대 택배장비가 동일 저장소 사용</li>
							<li>봉투 암호화(Envelope Encryption) 기반 JWE로 Stateless 유지 — KMS DEK 관리로 페이로드 암호화와 키 보안 동시 확보</li>
							<li>Spring Security로 6개 시스템 간 API 완전 격리 — 물류센터·장비·앱이 서로의 API를 침범하지 못하도록 선언적으로 설계</li>
							<li>객체 수준 인가(Object-Level Authorization) 적용 — 고객 A가 고객 B의 개인정보를 조회할 수 없도록 구조적으로 차단</li>
							<li>웹뷰 인증 연속성 처리, 주소록·쿠폰(등록·조회·사용·선물) 기능 개발, 오프쇼어 팀 연동 조율</li>
						</ul>
					</li>

					<li>
						<div class='font-semibold text-foreground'>
							<a href='/blog/doorstep-delivery' class='hover:underline'>방문택배 API · Batch 구축</a>
							<span class='ml-2 text-sm text-muted-foreground'>(2024.03–2024.10)</span>
						</div>
						<div class='mt-1 text-sm'>
							API/Batch 개발 · Java, Python / Spring Batch 5 / MWAA(Airflow) / Datadog
						</div>
						<ul class='ml-4 mt-2 list-disc space-y-1 text-sm'>
							<li>오픈 초기 일 1,000건 접수를 처리할 수 있도록 API·배치 흐름 구성</li>
							<li>
								알림톡이 DB 반영 전에 발송되는 문제를 방지하고자,
								<code class='rounded bg-muted px-1'>@TransactionalEventListener(AFTER_COMMIT)</code
								>으로 커밋 이후에만 발송하도록 처리
							</li>
							<li>운송장 상태별 로그를 Datadog으로 수집해 누락/이상 구간을 추적 가능하게 개선</li>
							<li>배치 실행 지연과 자원 낭비를 줄이고자 MWAA(Airflow) DAG 구조와 배치 자원을 튜닝</li>
						</ul>
					</li>

					<li>
						<div class='font-semibold text-foreground'>
							<a href='/blog/idc-aws-migration' class='hover:underline'>IDC → AWS 이관</a>
							<span class='ml-2 text-sm text-muted-foreground'>(2023.03–2024.02)</span>
						</div>
						<div class='mt-1 text-sm'>
							MWAA(Airflow) 구성 · Oracle SQL → ANSI SQL 전환 · Java / Python / SQL / CI/CD
						</div>
						<ul class='ml-4 mt-2 list-disc space-y-1 text-sm'>
							<li>수동 배포로 인한 실수와 작업 부담을 줄이고자, Airflow API로 커밋 시 이미지 태그가 자동 갱신되도록 CI/CD 흐름 구성</li>
							<li>5개 서비스 쿼리를 점진적으로 ANSI SQL로 전환(운영 중단 최소화)</li>
						</ul>
					</li>

					<li>
						<div class='font-semibold text-foreground'>
							<a href='/blog/datadog-log' class='hover:underline'>Datadog 로그 수집 체계 구축</a>
							<span class='ml-2 text-sm text-muted-foreground'>(2024.11–2024.12)</span>
						</div>
						<div class='mt-1 text-sm'>
							로그 포맷 표준화 / 개인정보 로그 핸들링 · Spring Boot 3 / Datadog / Marker
						</div>
						<ul class='ml-4 mt-2 list-disc space-y-1 text-sm'>
							<li>운영 중 데이터 변경 이력 추적이 어려웠던 문제를 해결하고자 CUD 로그 기준을 정의하고 Datadog으로 전송</li>
							<li>API마다 로그 포맷이 달라 이슈 추적이 어려웠던 점을 개선하고자, 전체 API에 Filter를 적용해 요청 정보를 일관된 형식으로 수집</li>
							<li>개인정보 포함 로그는 Marker로 분리해 미전달 처리</li>
						</ul>
					</li>
				</ul>
			</Card>

			<Card
				heading='GS 네트웍스'
				subheading='생활플랫폼팀 | 매니저 | 백엔드'
				date='Aug 2021 - Oct 2022'
				imagePath='/src/assets/logo_gs_lg-removebg-preview.png'
				altText='GS Networks'
				imageClass='h-12 w-auto md:-left-28'
			>
				<ul class='space-y-7 text-muted-foreground'>
					<li>
						<div class='font-semibold text-foreground'>
							<a href='/blog/affiliate-api' class='hover:underline'>제휴사 RESTful API 개발·운영</a>
