---
import PageLayout from '../layouts/BaseLayout.astro'
import Section from '../components/Section.astro'
import Card from '../components/Card.astro'
import ProjectCard from '../components/ProjectCard.astro'
import Label from '../components/Label.astro'
import SkillLayout from '../components/SkillLayout.astro'
import PostPreview from '@/components/blog/PostPreview.astro'

import { Image } from 'astro:assets'
import astro from '../assets/else-where.jpg'

import { sortMDByDate } from '@/utils'
import { fetchTistoryTopPosts } from '../utils/post'

const languages = ['java', 'kotlin', 'python', 'sql']
const frontend = ['typescript', 'tauri']
const backend = ['spring-boot', 'spring-batch', 'jpa']
const others = ['airflow', 'kubernetes', 'docker', 'postgres', 'valkey', 'git', 'ci/cd', 'datadog', 'aws', 'self-hosted']

const MAX_POSTS = 10
const tistoryPosts = await fetchTistoryTopPosts()
const allPostsByDate = sortMDByDate(tistoryPosts).slice(0, MAX_POSTS)
---

<PageLayout meta={{ title: 'Home' }}>
	<div class='flex w-full flex-col gap-y-10'>
		<section class='flex flex-col items-center gap-y-7'>
			<Image
				src={astro}
				alt='profile photo'
				class='h-36 w-auto rounded-full'
				loading='eager'
			/>

			<div class='flex flex-col items-center gap-y-4'>
				<h1 class='text-3xl font-bold'>물류·택배 시스템을 운영하며 인증, 배치를 개선해 온 백엔드 엔지니어 고형규입니다.</h1>
				<div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
					<Label title='GS 리테일'>
						<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' class='h-5 w-5' slot='icon'
						><path
							fill='currentColor'
							d='M4.615 20q-.69 0-1.152-.462Q3 19.075 3 18.385v-9.77q0-.69.463-1.152Q3.925 7 4.615 7H9V5.615q0-.69.463-1.152Q9.925 4 10.615 4h2.77q.69 0 1.153.463q.462.462.462 1.152V7h4.385q.69 0 1.152.463q.463.462.463 1.152v9.77q0 .69-.462 1.152q-.463.463-1.153.463zm0-1h14.77q.23 0 .423-.192q.192-.193.192-.423v-9.77q0-.23-.192-.423Q19.615 8 19.385 8H4.615q-.23 0-.423.192Q4 8.385 4 8.615v9.77q0 .23.192.423q.193.192.423.192M10 7h4V5.615q0-.23-.192-.423Q13.615 5 13.385 5h-2.77q-.23 0-.423.192q-.192.193-.192.423zM4 19V8z'
						></path></svg
						>
					</Label>
					<Label
						title='GitHub'
						as='a'
						href='https://github.com/GHGHGHKO'
						target='_blank'>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 16 16"
							slot="icon"
							class="h-5 w-5 text-foreground/75">
							<path
								fill="currentColor"
								d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13 -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07 -1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.548 7.548 0 0 1 2-.27c.68.003 1.36.092 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.001 8.001 0 0 0 16 8 c0-4.42-3.58-8-8-8z"
							></path>
						</svg>
					</Label>
					<Label
						title='Instagram'
						as='a'
						href='https://www.instagram.com/hg____ko/'
						target='_blank'>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5" slot="icon">
							<rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" fill="none" stroke-width="1.5"/>
							<circle cx="12" cy="12" r="3.5" stroke="currentColor" fill="none" stroke-width="1.5"/>
							<circle cx="17" cy="7" r="1" fill="currentColor"/>
						</svg>
					</Label>
					<Label title='gudrb963@gmail.com'>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 24 24"
							slot="icon"
							class="h-5 w-5 text-foreground/75"
						>
							<path
								fill="currentColor"
								d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 2v.01L12 13 4 6.01V6h16zM4 18V8l8 5 8-5v10H4z"
							/>
						</svg>
					</Label>
				</div>
			</div>
		</section>

		<Section title='About'>
			<div class="text-muted-foreground space-y-4">
				<p>
					물류·택배 시스템에서 인증, 배치, 데이터베이스, 모니터링 영역을 주로 담당해 왔습니다.
					시스템 확장과 함께 증가하는 운영 비용과 장애 대응 부담을 줄이는 개선 작업을 수행했습니다.
				</p>

				<p>
					세션 클러스터링 기반 인증 구조의 확장 한계를 해결하기 위해
					RSA(KMS) 기반 JWT 인증을 도입했고,
					전국 약 18,000대 단말과 우리동네GS 앱 인증 구조를 정리했습니다.
				</p>

				<p>
					IDC 환경을 AWS로 전환하며 DB 마이그레이션과 배치 구조 정리를 진행했고,
					운영 비용 절감과 장애 대응 시간 단축에 기여했습니다.
					Datadog APM과 로그를 활용해 운영 이슈를 빠르게 확인할 수 있는 환경을 구성했습니다.
				</p>
			</div>
		</Section>

		<Section title='TL;DR'>
			<Card
				heading='💰 비용 절감'
				imageClass='h-12 w-auto md:-left-28'
			>
				<ul class='ml-4 list-disc text-muted-foreground'>
					<li>EDB → Aurora PostgreSQL 마이그레이션</li>
					<li>Airflow DAG 270개 → 180개 정리</li>
					<li>알림톡 에이전트 16개 → 8개 통합</li>
					<li>IDC → AWS 전환으로 연 운영비 5억 → 2억 수준으로 감소 기여</li>
				</ul>
			</Card>
			<Card
				heading='🔒 보안'
				imageClass='h-12 w-auto md:-left-28'
			>
				<ul class='ml-4 list-disc text-muted-foreground'>
					<li>세션 클러스터링 기반 인증 구조를 JWT로 점진적 변경</li>
					<li>RSA(KMS) 기반 JWT 인증 도입</li>
					<li>단말 및 모바일 앱 인증 구조 통합</li>
				</ul>
			</Card>
			<Card
				heading='⚙️ 배치 / 안정성'
				imageClass='h-12 w-auto md:-left-28'
			>
				<ul class='ml-4 list-disc text-muted-foreground'>
					<li>K8s Airflow 배치 구조 정리</li>
					<li>배치 실패율 30% → 5% 수준으로 개선</li>
					<li>SLA miss 20회/일 → 3회/일 수준으로 감소</li>
				</ul>
			</Card>
			<Card
				heading='📊 모니터링'
				imageClass='h-12 w-auto md:-left-28'
			>
				<ul class='ml-4 list-disc text-muted-foreground'>
					<li>Datadog APM 및 로그 수집 환경 구축</li>
					<li>개인정보 Marker 기반 로그 필터링 적용</li>
					<li>운영 대응 시간 1시간 → 30분 수준으로 단축</li>
				</ul>
			</Card>
		</Section>
		{
			allPostsByDate.length > 0 && (
				<Section title='Posts'>
					<ul class='flex flex-col gap-y-2'>
						{allPostsByDate.map((p) => (
							<li class='flex flex-col gap-x-2 sm:flex-row'>
								<PostPreview post={p} />
							</li>
						))}
					</ul>
				</Section>
			)
		}

		<Section title='Experience'>
			<Card
				heading='GS 리테일'
				subheading='물류DX | 매니저 | 백엔드'
				date='Oct 2022 - Now'
				imagePath='/src/assets/logo_gs_lg-removebg-preview.png'
				altText='Lorem, ipsum dolor sit'
				imageClass='h-12 w-auto md:-left-28'
			>
				<ul class='ml-4 list-disc text-muted-foreground space-y-4'>
					<li>
						<b>RSA(KMS) 기반 JWT 인증 체계 구축</b>
						<ul class="ml-6 list-disc">
							<li>세션 클러스터링 기반 인증 구조가 단말 수 증가에 따라 확장성과 운영 부담이 커짐</li>
							<li>RSA(KMS) 기반 JWT 인증 도입, 공개키 검증 구조로 인증 서버 의존도 제거</li>
							<li>전국 약 18,000대 단말 및 우리동네GS 앱 인증 구조 통합, 로그인 응답 1초 이내로 운영</li>
						</ul>
					</li>

					<li>
						<b>IDC → AWS 클라우드 전환</b>
						<ul class="ml-6 list-disc">
							<li>IDC 환경에서 고정 비용과 DB 라이선스 비용 부담이 지속적으로 증가</li>
							<li>EDB → Aurora PostgreSQL 마이그레이션, 비표준 쿼리 정리</li>
							<li>연 운영비 5억 → 2억 수준 절감, 택배 서비스 흑자 전환에 기여</li>
						</ul>
					</li>

					<li>
						<b>알림톡 에이전트 통합</b>
						<ul class="ml-6 list-disc">
							<li>에이전트와 DB 테이블이 과도하게 분산되어 운영·장애 분석이 어려웠음</li>
							<li>미사용 에이전트 및 테이블 정리, 에이전트 통합</li>
							<li>에이전트 16 → 8, EC2 자원 약 50% 절감, 장애 분석 시간 감소</li>
						</ul>
					</li>

					<li>
						<b>헥사고날 아키텍처 + SpringEvent 도입</b>
						<ul class="ml-6 list-disc">
							<li>하나의 프로젝트에 우리동네GS, 방문택배, 물류센터 로직이 한 흐름에 묶여 변경·확장이 어려웠음</li>
							<li>도메인/어댑터/인프라 분리, 이벤트 기반 처리 구조 도입</li>
							<li>방문택배 서비스 오픈(일 3,000건+), API 응답 2초 이내로 운영</li>
						</ul>
					</li>

					<li>
						<b>Datadog 로그 수집 체계 구축</b>
						<ul class="ml-6 list-disc">
							<li>장애 발생 시 로그 파악에 시간이 오래 걸렸음</li>
							<li>로그 통합 조회 환경 구성, 개인정보 Marker 기반 필터링 적용</li>
							<li>운영 대응 시간 1시간 → 20분 수준으로 단축</li>
						</ul>
					</li>
				</ul>
			</Card>
			<Card
				heading='GS 네트웍스'
				subheading='시스템파트 | 매니저 | 백엔드'
				date='Aug 2021 - Oct 2022'
				imagePath='/src/assets/logo_gs_lg-removebg-preview.png'
				altText='Lorem, ipsum dolor sit'
				imageClass='h-12 w-auto md:-left-28'
			>
				<ul class='ml-4 list-disc text-muted-foreground space-y-4'>
					<li>
						<b>제휴사 RESTful API 개발 및 운영</b>
						<ul class="ml-6 list-disc">
							<li>제휴사 증가로 요구사항 대응과 연동 방식이 제각각이라 운영 효율이 낮았음</li>
							<li>제휴사 요구사항 정리 후 API 통합 및 신규 개발, 문서화 정비</li>
							<li>신규 제휴사 30곳 오픈, 50곳 이상 운영, 일 처리량 1,000건 → 10,000건 수준 증가</li>
						</ul>
					</li>

					<li>
						<b>K8s Airflow 배치 시스템 경량화</b>
						<ul class="ml-6 list-disc">
							<li>DAG 수 증가와 짧은 스케줄로 배치 실패와 SLA miss가 빈번하게 발생</li>
							<li>불필요 DAG 제거, 스케줄 통합, 일부 작업 Spring Batch 전환</li>
							<li>DAG 270 → 180, 배치 실패율 40% → 15%, SLA miss 20회/일 → 10회/일</li>
						</ul>
					</li>
				</ul>
			</Card>
			<Card
				heading='마인드패스'
				subheading='대표 | PM'
				date='Dec 2018 - Jan 2021'
				imagePath='/src/assets/mindpass.png'
				altText='Lorem, ipsum dolor sit'
				imageClass='h-7 w-auto md:-left-28'
			>
				<ul class='ml-4 list-disc text-muted-foreground space-y-4'>
					<li>
						<b>창업 및 초기 활동</b>
						<ul class="ml-6 list-disc">
							<li>대학교 동기 2명과 창업</li>
						</ul>
					</li>

					<li>
						<b>AI 기반 프로젝트</b>
						<ul class="ml-6 list-disc">
							<li>GoogleNet 기반 한국어 독화 MVP 제작</li>
							<li>GoogleNet 기반 의류 분류 모델 MVP 제작 및 GPU 20TFlops 대여 수혜</li>
							<li>치매 환자 낙상 방지 시스템 MVP 개발 → 건대 병원 파일럿 테스트 (특허 등록 지원)</li>
						</ul>
					</li>

					<li>
						<b>투자 및 지원 수혜</b>
						<ul class="ml-6 list-disc">
							<li>5,000만원 투자 수혜 (기술혁신형창업기업지원사업, 기술보증기금)</li>
							<li>3,000만원 투자 수혜 (위치 기반 메모 알람 서비스, 맞춤형성장지원프로그램, 대전TP)</li>
						</ul>
					</li>

					<li>
						<b>아웃소싱</b>
						<ul class="ml-6 list-disc">
							<li>DJI Framework 기반 Robomaster S1 콘텐츠 개발</li>
							<li>CMS(강의 웹사이트) Backoffice RESTful API 개발</li>
						</ul>
					</li>
				</ul>
			</Card>
			<Card
				heading='대한민국공군'
				subheading='병장 | 만기전역 | 위성통신병'
				date='Jan 2015 - Jan 2017'
				imagePath='/src/assets/Republic_of_Korea_Air_Force_emblem.png'
				altText='Lorem, ipsum dolor sit'
				imageClass='h-20 w-auto md:-left-24'
			>
				<ul class='ml-4 list-disc text-muted-foreground'>
					<li>김포 근무, 자동 추적 위성 안테나, 수동 위성 안테나 운영</li>
				</ul>
			</Card>
		</Section>

		<Section title='Education'>
			<Card
				heading='건국대학교 글로컬캠퍼스'
				subheading='졸업 | 학사 | 컴퓨터공학과 '
				date='Mar 2014 - Feb 2021'
				imagePath='/src/assets/signature-logo_large-removebg-preview.png'
				altText='Lorem, ipsum dolor sit'
				imageClass='h-16 w-auto md:-left-20'
			>
				<ul class='ml-4 list-disc text-muted-foreground space-y-4'>
					<li>
						<b>학과 공용 웹 서버 구축 및 운영</b>
						<ul class="ml-6 list-disc">
							<li>전공 수업과 개인 프로젝트를 진행하기 위한 공용 서버 환경이 없어 학생들이 각자 로컬 환경에 의존하며 실습·과제 수행에 불편이 있었음</li>
							<li>전교 학생을 위한 공용 웹 서버 구축 및 운영</li>
							<li>개발·실습에 필요한 패키지 및 런타임 환경 설치·관리</li>
							<li>관리되지 않던 BareMetal 서버를 Ubuntu 기반 실습 서버로 전환</li>
							<li>Windows Server 기반 실습 PC 유지보수 및 Switch Looping 문제 해결</li>
						</ul>
					</li>

					<li>
						<b>네트워크 장애 대응</b>
						<ul class="ml-6 list-disc">
							<li>학과 PC 네트워크 장애로 정상적인 수업 진행이 어려운 상황이 발생함</li>
							<li>외주 업체와 협업하여 네트워크 스위치 루핑이 발생한 랜선을 추적·차단하여 장애 원인 제거</li>
						</ul>
					</li>

					<li>
						<b>창업 및 프로젝트</b>
						<ul class="ml-6 list-disc">
							<li>마인드패스 창업</li>
							<li>Raspberry Pi 기반 치매 환자 낙상 방지 시스템 MVP 제작</li>
							<li>의료기관 협력 하에 실제 임상 환경에서 파일럿 테스트 진행</li>
						</ul>
					</li>
				</ul>

			</Card>
			<Card
				heading='대헌공업고등학교'
				subheading='졸업 | 정보통신과'
				date='Mar 2011 - Feb 2014'
				altText='Lorem, ipsum dolor sit'
			>
				<ul class='ml-4 list-disc text-muted-foreground'>
					<li>C, AVR 기반의 모바일로보틱스를 활용한 기능경진대회 출전</li>
				</ul>
			</Card>
